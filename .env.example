# Server
SERVER_ADDR=:8080
SERVER_ENV=development              # production, development

# Database
DATABASE_URL=postgres://shellvault:shellvault@localhost:5432/shellvault?sslmode=disable

# JWT
JWT_PRIVATE_KEY_PATH=./keys/ed25519.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# OAuth (leave empty to disable)
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_KEY_PATH=
OAUTH_GOOGLE_CLIENT_ID=

# Mail (leave empty to use noop mailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sshvault.app

# Billing (leave empty = Self-Hosted / billing disabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
APPLE_SHARED_SECRET=
GOOGLE_SERVICE_ACCOUNT_PATH=

# Vault
VAULT_MAX_SIZE_MB=50
VAULT_HISTORY_LIMIT=10

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# Backup (for CLI auto-backup)
BACKUP_DIR=./backups
BACKUP_INTERVAL=24h                 # Auto-backup interval
BACKUP_RETENTION=7                  # Keep last N backups
