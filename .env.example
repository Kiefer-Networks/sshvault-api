# Server
SERVER_ADDR=127.0.0.1:8080           # Bind to localhost only — reverse proxy required
HOST_PORT=127.0.0.1:8080             # Docker host:port mapping (default: 127.0.0.1:8080)
SERVER_ENV=production                # production, development
APP_BASE_URL=https://app.example.com # Frontend URL (for emails, redirects)
API_BASE_URL=https://api.example.com # Public API URL (behind reverse proxy)

# Trusted Proxies (CIDR notation, comma-separated)
# Only connections from these IPs may set X-Forwarded-For.
# Caddy/Nginx on same host: 127.0.0.1/8,::1/128
# Traefik in Docker network: 172.16.0.0/12
TRUSTED_PROXIES=127.0.0.1/8,::1/128

# Database
DATABASE_URL=postgres://sshvault:CHANGE_ME@localhost:5432/sshvault?sslmode=disable
POSTGRES_PASSWORD=CHANGE_ME          # Used by Docker Compose for postgres container

# JWT
JWT_PRIVATE_KEY_PATH=./keys/ed25519.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Mail (leave empty to use noop mailer — logs to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Vault
VAULT_MAX_SIZE_MB=50
VAULT_HISTORY_LIMIT=10

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# Backup (for CLI auto-backup)
BACKUP_DIR=./backups
BACKUP_INTERVAL=24h
BACKUP_RETENTION=7

# CORS (comma-separated origins, leave empty for no CORS)
CORS_ORIGINS=

# Server Identity
SERVER_ID=sshvault-primary

# Logging (leave LOG_FILE_PATH empty to log to stdout only)
LOG_FILE_PATH=
LOG_MAX_SIZE_MB=100
LOG_MAX_AGE_DAYS=90
LOG_MAX_BACKUPS=10
LOG_COMPRESS=true

# Audit
AUDIT_RETENTION_DAYS=365
AUDIT_BUFFER_SIZE=4096
